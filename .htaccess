<IfModule mod_rewrite.c>
Options +FollowSymLinks
RewriteEngine On

# Canonicalize host: force non-www (fixes www + non-www both resolving as duplicate sites)
RewriteCond %{HTTP_HOST} ^www\.dapperstech\.com$ [NC]
RewriteRule ^(.*)$ https://dapperstech.com/$1 [L,R=301]

RewriteCond %{REQUEST_URI} !^/public/

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f



RewriteRule ^(.*)$ /public/$1 
#RewriteRule ^ index.php [L]
RewriteRule ^(/)?$ public/index.php [L] 
</IfModule>
# <Files .env>
#     Order allow,deny
#     Deny from all
# </Files>
<FilesMatch "^\.env|^composer\.(json|lock)|^artisan|^readme\.md|^server\.php">
    Order allow,deny
    Deny from all
</FilesMatch>
